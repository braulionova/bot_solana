# ── Helios Gold V2 — Environment Variables ──
# Copy to /etc/helios/helios.env and fill in your values.

# ── RPC ──
RPC_URL=https://api.mainnet-beta.solana.com
WS_RPC_URL=wss://api.mainnet-beta.solana.com
POOL_RPC_URL=https://api.mainnet-beta.solana.com
SIM_RPC_URL=https://api.mainnet-beta.solana.com
POOL_RPC_FALLBACK_URL=https://api.mainnet-beta.solana.com

# ── Spy Node ──
SPY_TVU_PORT=8002
SPY_JITO_PORT=20000
SPY_UDP_THREADS=4
GOSSIP_ENTRYPOINT=entrypoint.mainnet-beta.solana.com:8001
BIND_ADDR=0.0.0.0
SIG_VERIFY=false
IDENTITY_KEYPAIR=/path/to/identity.json

# ── Executor ──
PAYER_KEYPAIR=/path/to/wallet.json
MIN_NET_PROFIT=5000
DRY_RUN=true
FAST_ARB=true
DIRECT_SWAP=true
JITO_ONLY=true

# ── Jito ──
JITO_ENDPOINT=https://frankfurt.mainnet.block-engine.jito.wtf

# ── Helius (optional) ──
HELIUS_API_KEY=your_helius_api_key_here

# ── PostgreSQL ──
DATABASE_URL=postgres://postgres:your_password@127.0.0.1/helios

# ── Telegram (optional) ──
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Redis ──
REDIS_URL=redis://127.0.0.1/

# ── Feature flags ──
VAULT_REFRESH_ENABLED=false
SQLITE_ROUTE_FEED=false
ERPC_SHREDS_ENABLED=false
NO_AGAVE_MODE=false
