# ── Helios Gold V2 – Environment Configuration ───────────────────────────────
# Copy to /etc/helios/helios.env and fill in real values.

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Primary RPC (Chainstack / Quicknode / Triton recommended for low latency)
RPC_URL=https://api.mainnet-beta.solana.com
# Chainstack example: https://solana-mainnet.core.chainstack.com/YOUR_KEY

# ── Spy Node ─────────────────────────────────────────────────────────────────
SPY_TVU_PORT=8002
SPY_JITO_PORT=20000
SPY_UDP_THREADS=4
GOSSIP_ENTRYPOINT=entrypoint.mainnet-beta.solana.com:8001
# Optional public IP / DNS to advertise in gossip. If empty, the node asks the
# entrypoint ip-echo service for its public IP.
# GOSSIP_HOST=
# 0 = auto-pick an available gossip port.
GOSSIP_PORT=0
# Optional manual override if ip-echo shred-version detection is unavailable.
# GOSSIP_SHRED_VERSION=
BIND_ADDR=0.0.0.0
DEDUP_CACHE_SIZE=10000
CHANNEL_CAPACITY=4096
SIG_VERIFY=true
IDENTITY_KEYPAIR=/etc/helios/identity.json

# ── Executor ─────────────────────────────────────────────────────────────────
PAYER_KEYPAIR=/root/solana-bot/wallet.json
# 50000 lamports = $0.005 minimum profit to execute
MIN_NET_PROFIT=50000
# Set to true to simulate but NOT send bundles (testing)
DRY_RUN=false

# ── Jito Block Engine ────────────────────────────────────────────────────────
# Frankfurt endpoint (closer to Contabo EU VPS)
JITO_ENDPOINT=https://frankfurt.mainnet.block-engine.jito.wtf
JITO_TIP_LAMPORTS=10000

# ── Jito ShredStream Proxy ───────────────────────────────────────────────────
# `docker` is the fastest way to run the official proxy; switch to `native`
# only if you installed the binary yourself.
JITO_SHREDSTREAM_MODE=docker
# Official image tag used by the wrapper in docker mode.
JITO_SHREDSTREAM_IMAGE=jitolabs/jito-shredstream-proxy:latest
# Install/build jito-shredstream-proxy separately and point this at the binary.
JITO_SHREDSTREAM_PROXY_BIN=/usr/local/bin/jito-shredstream-proxy
# Default subcommand for the native proxy binary.
JITO_SHREDSTREAM_SUBCOMMAND=shredstream
# Auth keypair approved by Jito for ShredStream / Block Engine access.
JITO_SHREDSTREAM_AUTH_KEYPAIR=/etc/helios/jito-auth-keypair.json
# Regional Block Engine URL used by the proxy.
JITO_SHREDSTREAM_BLOCK_ENGINE_URL=https://frankfurt.mainnet.block-engine.jito.wtf
# Comma-separated preferred regions for your VPS location.
JITO_SHREDSTREAM_DESIRED_REGIONS=frankfurt,amsterdam
# UDP destination for the official Jito proxy.
# Default to Agave TVU so the validator receives ShredStream directly.
# Override this if you want to feed another local consumer instead.
JITO_SHREDSTREAM_DEST_IP_PORTS=127.0.0.1:8802
# Optional passthrough for less common proxy flags.
# JITO_SHREDSTREAM_EXTRA_ARGS=

# ── Monitoring ───────────────────────────────────────────────────────────────
METRICS_PORT=9090
STATS_INTERVAL_SECS=30

# ── Telegram Alerts ──────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=
# Your personal chat ID or group ID (use @userinfobot to get yours)
TELEGRAM_CHAT_ID=

